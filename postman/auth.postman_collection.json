{
	"info": {
		"name": "Auth API Tests",
		"description": "Collection để test các API xác thực (đăng ký, đăng nhập)",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Register User",
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"userCode\": \"USER001\",\n  \"username\": \"admin\",\n  \"email\": \"admin@example.com\",\n  \"password\": \"123456\",\n  \"fullName\": \"Administrator\",\n  \"phone\": \"0901234567\",\n  \"roleCode\": \"ADMIN\"\n}"
				},
				"url": {
					"raw": "{{baseUrl}}/api/auth/register",
					"host": ["{{baseUrl}}"],
					"path": ["api", "auth", "register"]
				}
			}
		},
		{
			"name": "Login with Username",
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"login\": \"admin\",\n  \"password\": \"123456\"\n}"
				},
				"url": {
					"raw": "{{baseUrl}}/api/auth/login",
					"host": ["{{baseUrl}}"],
					"path": ["api", "auth", "login"]
				},
				"description": "Đăng nhập bằng username"
			}
		},
		{
			"name": "Login with Email",
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"login\": \"admin@example.com\",\n  \"password\": \"123456\"\n}"
				},
				"url": {
					"raw": "{{baseUrl}}/api/auth/login",
					"host": ["{{baseUrl}}"],
					"path": ["api", "auth", "login"]
				},
				"description": "Đăng nhập bằng email"
			}
		},
		{
			"name": "Get Current User Info",
			"request": {
				"method": "GET",
				"header": [
					{
						"key": "Authorization",
						"value": "Bearer {{globalToken}}"
					}
				],
				"url": {
					"raw": "{{baseUrl}}/api/auth/me",
					"host": ["{{baseUrl}}"],
					"path": ["api", "auth", "me"]
				},
				"description": "Lấy thông tin user hiện tại (cần token)"
			}
		},
		{
			"name": "Register Staff User",
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"userCode\": \"STAFF001\",\n  \"username\": \"staff1\",\n  \"email\": \"staff1@example.com\",\n  \"password\": \"123456\",\n  \"fullName\": \"Nhân viên 1\",\n  \"phone\": \"0907654321\",\n  \"roleCode\": \"STAFF\"\n}"
				},
				"url": {
					"raw": "{{baseUrl}}/api/auth/register",
					"host": ["{{baseUrl}}"],
					"path": ["api", "auth", "register"]
				},
				"description": "Đăng ký user với quyền STAFF"
			}
		},
		{
			"name": "Register Regular User",
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"userCode\": \"USER002\",\n  \"username\": \"user1\",\n  \"email\": \"user1@example.com\",\n  \"password\": \"123456\",\n  \"fullName\": \"Người dùng 1\",\n  \"phone\": \"0912345678\"\n}"
				},
				"url": {
					"raw": "{{baseUrl}}/api/auth/register",
					"host": ["{{baseUrl}}"],
					"path": ["api", "auth", "register"]
				},
				"description": "Đăng ký user thường (roleCode mặc định là USER)"
			}
		}
	],
	"variable": [
		{
			"key": "baseUrl",
			"value": "http://localhost:3000"
		},
		{
			"key": "token",
			"value": ""
		}
	]
}
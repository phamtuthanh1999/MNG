{
	"info": {
		"name": "Product API Tests",
		"description": "Collection để test các API của sản phẩm",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Create Product",
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					},
					{
						"key": "Authorization",
						"value": "Bearer {{globalToken}}"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"PD_CD\": \"SP001\",\n  \"PD_NM\": \"Sản phẩm test\",\n  \"STORE_ID\": \"CH001\",\n  \"QUANTITY\": 100,\n  \"UNIT_CD\": \"CAI\",\n  \"DESCRIPTION\": \"Mô tả sản phẩm test\",\n  \"IMG_URL\": \"https://example.com/image.jpg\"\n}"
				},
				"url": {
					"raw": "{{baseUrl}}/api/products",
					"host": ["{{baseUrl}}"],
					"path": ["api", "products"]
				}
			}
		},
		{
			"name": "Get All Products",
			"request": {
				"method": "GET",
				"header": [
					{
						"key": "Authorization",
						"value": "Bearer {{globalToken}}"
					}
				],
				"url": {
					"raw": "{{baseUrl}}/api/products",
					"host": ["{{baseUrl}}"],
					"path": ["api", "products"]
				}
			}
		},
		{
			"name": "Get Product by ID",
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{baseUrl}}/api/products/1",
					"host": ["{{baseUrl}}"],
					"path": ["api", "products", "1"]
				}
			}
		},
		{
			"name": "Update Product",
			"request": {
				"method": "PUT",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					},
					{
						"key": "Authorization",
						"value": "Bearer {{globalToken}}"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"PD_NM\": \"Sản phẩm đã cập nhật\",\n  \"QUANTITY\": 150,\n  \"DESCRIPTION\": \"Mô tả đã được cập nhật\"\n}"
				},
				"url": {
					"raw": "{{baseUrl}}/api/products/1",
					"host": ["{{baseUrl}}"],
					"path": ["api", "products", "1"]
				}
			}
		},
		{
			"name": "Search Products",
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{baseUrl}}/api/products/search?keyword=test",
					"host": ["{{baseUrl}}"],
					"path": ["api", "products", "search"],
					"query": [
						{
							"key": "keyword",
							"value": "test"
						}
					]
				}
			}
		},
		{
			"name": "Delete Product",
			"request": {
				"method": "DELETE",
				"header": [],
				"url": {
					"raw": "{{baseUrl}}/api/products/1",
					"host": ["{{baseUrl}}"],
					"path": ["api", "products", "1"]
				}
			}
		}
	],
	"variable": [
		{
			"key": "baseUrl",
			"value": "http://localhost:3000"
		},
		{
			"key": "token",
			"value": "your-jwt-token-here"
		},
		{
			"key": "globalToken",
			"value": "use-global-auth-collection-to-set"
		}
	]
}
    {
      "name": "Verify Multiple Product Codes Sequential",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 201', function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "",
              "pm.test('Verify sequential code generation', function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.have.property('PD_CD');",
              "    pm.expect(jsonData.PD_CD).to.match(/^PD\\d{4}$/);",
              "    ",
              "    // Store the generated code for comparison",
              "    pm.globals.set('last_product_code', jsonData.PD_CD);",
              "    console.log('Sequential Product Code:', jsonData.PD_CD);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"PD_NM\": \"Sequential Product Test {{$randomInt}}\",\n  \"STORE_ID\": \"ST0001\",\n  \"QUANTITY\": 5,\n  \"UNIT_CD\": \"UN0001\",\n  \"DESCRIPTION\": \"Test sequential code generation\",\n  \"USER_LOGIN\": \"admin\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/products",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "products"
          ]
        }
      }
    }

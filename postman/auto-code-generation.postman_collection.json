{
  "info": {
    "name": "Auto Code Generation Tests",
    "description": "Test API endpoints để kiểm tra việc tự động tạo code cho các trường *_CD",
    "version": "1.0.0"
  },
  "item": [
    {
      "name": "Test Auto Generate Product Code (PD_CD)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 201', function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "",
              "pm.test('Response has PD_CD auto generated', function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.have.property('PD_CD');",
              "    pm.expect(jsonData.PD_CD).to.match(/^PD\\d{4}$/);",
              "    console.log('Generated Product Code:', jsonData.PD_CD);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"PD_NM\": \"Test Product Auto Code\",\n  \"STORE_ID\": \"ST0001\",\n  \"QUANTITY\": 10,\n  \"UNIT_CD\": \"UN0001\",\n  \"DESCRIPTION\": \"Test tự động tạo mã sản phẩm\",\n  \"IMG_URL\": \"https://example.com/image.jpg\",\n  \"USER_LOGIN\": \"admin\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/products",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "products"
          ]
        }
      }
    },

{
  "info": {
    "name": "Export Management API",
    "description": "API collection for testing Export and Export Detail management endpoints",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "1234567890"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{auth_token}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:3000/api"
    },
    {
      "key": "auth_token",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Export Management",
      "item": [
        {
          "name": "Create Export",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"EXPORT_CD\": \"EXP001\",\n  \"STORE_CD\": \"STORE001\",\n  \"EXPORT_DT\": \"2024-03-10T16:00:00Z\",\n  \"NOTE\": \"Xuất hàng cho khách hàng A\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/exports",
              "host": ["{{base_url}}"],
              "path": ["exports"]
            }
          }
        },
        {
          "name": "Get All Exports",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/exports",
              "host": ["{{base_url}}"],
              "path": ["exports"]
            }
          }
        },
        {
          "name": "Get Export by ID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/exports/1",
              "host": ["{{base_url}}"],
              "path": ["exports", "1"]
            }
          }
        },
        {
          "name": "Search Exports",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/exports/search?keyword=EXP",
              "host": ["{{base_url}}"],
              "path": ["exports", "search"],
              "query": [
                {
                  "key": "keyword",
                  "value": "EXP"
                }
              ]
            }
          }
        },
        {
          "name": "Update Export",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"EXPORT_CD\": \"EXP001_UPDATED\",\n  \"STORE_CD\": \"STORE001\",\n  \"EXPORT_DT\": \"2024-03-10T16:00:00Z\",\n  \"NOTE\": \"Xuất hàng cho khách hàng A - đã cập nhật\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/exports/1",
              "host": ["{{base_url}}"],
              "path": ["exports", "1"]
            }
          }
        },
        {
          "name": "Delete Export",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/exports/1",
              "host": ["{{base_url}}"],
              "path": ["exports", "1"]
            }
          }
        }
      ]
    },
    {
      "name": "Export Detail Management",
      "item": [
        {
          "name": "Create Export Detail",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"EXPORT_ID\": 1,\n  \"PD_CD\": \"PD001\",\n  \"UNIT_CD\": \"PCS\",\n  \"QUANTITY\": 50\n}"
            },
            "url": {
              "raw": "{{base_url}}/exports/details",
              "host": ["{{base_url}}"],
              "path": ["exports", "details"]
            }
          }
        },
        {
          "name": "Get Export Details by Export ID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/exports/1/details",
              "host": ["{{base_url}}"],
              "path": ["exports", "1", "details"]
            }
          }
        },
        {
          "name": "Get Export Detail by ID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/exports/details/1",
              "host": ["{{base_url}}"],
              "path": ["exports", "details", "1"]
            }
          }
        },
        {
          "name": "Update Export Detail",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"PD_CD\": \"PD001_UPDATED\",\n  \"UNIT_CD\": \"PCS\",\n  \"QUANTITY\": 75\n}"
            },
            "url": {
              "raw": "{{base_url}}/exports/details/1",
              "host": ["{{base_url}}"],
              "path": ["exports", "details", "1"]
            }
          }
        },
        {
          "name": "Delete Export Detail",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/exports/details/1",
              "host": ["{{base_url}}"],
              "path": ["exports", "details", "1"]
            }
          }
        }
      ]
    }
  ]
}
{
	"info": {
		"name": "Store API Tests",
		"description": "Collection để test các API của cửa hàng",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Create Store",
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					},
					{
						"key": "Authorization",
						"value": "Bearer {{globalToken}}"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"STORE_CD\": \"CH001\",\n  \"STORE_NM\": \"Cửa hàng chính\",\n  \"STORE_TYPE\": \"MAIN\",\n  \"ADDRESS\": \"123 Đường ABC, Quận 1, TP.HCM\",\n  \"PHONE\": \"0901234567\",\n  \"IS_ACTIVE\": true\n}"
				},
				"url": {
					"raw": "{{baseUrl}}/api/stores",
					"host": ["{{baseUrl}}"],
					"path": ["api", "stores"]
				}
			}
		},
		{
			"name": "Get All Stores",
			"request": {
				"method": "GET",
				"header": [
					{
						"key": "Authorization",
						"value": "Bearer {{globalToken}}"
					}
				],
				"url": {
					"raw": "{{baseUrl}}/api/stores",
					"host": ["{{baseUrl}}"],
					"path": ["api", "stores"]
				}
			}
		},
		{
			"name": "Get Store by ID",
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{baseUrl}}/api/stores/1",
					"host": ["{{baseUrl}}"],
					"path": ["api", "stores", "1"]
				}
			}
		},
		{
			"name": "Get Store Users",
			"request": {
				"method": "GET",
				"header": [
					{
						"key": "Authorization",
						"value": "Bearer {{globalToken}}"
					}
				],
				"url": {
					"raw": "{{baseUrl}}/api/stores/CH001/users",
					"host": ["{{baseUrl}}"],
					"path": ["api", "stores", "CH001", "users"]
				}
			}
		},
		{
			"name": "Update Store",
			"request": {
				"method": "PUT",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					},
					{
						"key": "Authorization",
						"value": "Bearer {{globalToken}}"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"STORE_NM\": \"Cửa hàng đã cập nhật\",\n  \"ADDRESS\": \"456 Đường XYZ, Quận 2, TP.HCM\",\n  \"PHONE\": \"0907654321\",\n  \"IS_ACTIVE\": true\n}"
				},
				"url": {
					"raw": "{{baseUrl}}/api/stores/1",
					"host": ["{{baseUrl}}"],
					"path": ["api", "stores", "1"]
				}
			}
		},
		{
			"name": "Search Stores",
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{baseUrl}}/api/stores/search?keyword=chính",
					"host": ["{{baseUrl}}"],
					"path": ["api", "stores", "search"],
					"query": [
						{
							"key": "keyword",
							"value": "chính"
						}
					]
				}
			}
		},
		{
			"name": "Delete Store",
			"request": {
				"method": "DELETE",
				"header": [],
				"url": {
					"raw": "{{baseUrl}}/api/stores/1",
					"host": ["{{baseUrl}}"],
					"path": ["api", "stores", "1"]
				}
			}
		}
	],
	"variable": [
		{
			"key": "baseUrl",
			"value": "http://localhost:3000"
		},
		{
			"key": "token",
			"value": "your-jwt-token-here"
		},
		{
			"key": "globalToken",
			"value": "use-global-auth-collection-to-set"
		}
	]
}